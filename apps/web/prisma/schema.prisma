// Lansport Analytics - Database Schema
// Managed by Prisma — edit this file, then run: npx prisma db push (dev) or prisma migrate deploy (prod)
// All models use @map / @@map to ensure clean snake_case column names in PostgreSQL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
  CONTRA_ASSET
}

// ─────────────────────────────────────────────────────────────────────────────
// Chart of Accounts — master reference (92 accounts)
// ─────────────────────────────────────────────────────────────────────────────

model Account {
  id            Int         @id @default(autoincrement())
  accountNumber String      @unique @map("account_number")
  name          String
  type          AccountType
  normalBalance String      @map("normal_balance") // "DEBIT" or "CREDIT"
  createdAt     DateTime    @default(now()) @map("created_at")

  journalEntries  JournalEntry[]
  periodSummaries PeriodSummary[]

  revenueForProperties Property[] @relation("RevenueAccount")
  rmForProperties      Property[] @relation("RMAccount")
  levyForProperties    Property[] @relation("LevyAccount")

  @@index([type])
  @@index([accountNumber])
  @@map("accounts")
}

// ─────────────────────────────────────────────────────────────────────────────
// General Ledger — all journal entries (~1,968 rows in current workbook)
// ─────────────────────────────────────────────────────────────────────────────

model JournalEntry {
  id          Int      @id @default(autoincrement())
  date        DateTime
  accountId   Int      @map("account_id")
  account     Account  @relation(fields: [accountId], references: [id])
  description String
  debit       Decimal  @default(0) @db.Decimal(15, 2)
  credit      Decimal  @default(0) @db.Decimal(15, 2)
  uploadId    Int      @map("upload_id")
  upload      UploadHistory @relation(fields: [uploadId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([date])
  @@index([accountId])
  @@index([uploadId])
  @@map("journal_entries")
}

// ─────────────────────────────────────────────────────────────────────────────
// Property registry — the 17 rental units
// Groups: "Main Complex" (Units 16-32), "Mn Block" (Mn8-Mn9), "Standalone"
// ─────────────────────────────────────────────────────────────────────────────

model Property {
  id           Int     @id @default(autoincrement())
  name         String  @unique  // e.g. "Unit 16", "Glaudina House"
  group        String           // "Main Complex" | "Mn Block" | "Standalone"
  displayOrder Int     @default(0) @map("display_order")

  revenueAccountId Int     @map("revenue_account_id")
  revenueAccount   Account @relation("RevenueAccount", fields: [revenueAccountId], references: [id])

  rmAccountId  Int?    @map("rm_account_id")
  rmAccount    Account? @relation("RMAccount", fields: [rmAccountId], references: [id])

  levyAccountId Int?   @map("levy_account_id")
  levyAccount   Account? @relation("LevyAccount", fields: [levyAccountId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@index([group])
  @@map("properties")
}

// ─────────────────────────────────────────────────────────────────────────────
// Period summaries — pre-aggregated for fast dashboard queries
// ─────────────────────────────────────────────────────────────────────────────

model PeriodSummary {
  id          Int      @id @default(autoincrement())
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")
  accountId   Int      @map("account_id")
  account     Account  @relation(fields: [accountId], references: [id])
  totalDebit  Decimal  @default(0) @db.Decimal(15, 2) @map("total_debit")
  totalCredit Decimal  @default(0) @db.Decimal(15, 2) @map("total_credit")
  net         Decimal  @default(0) @db.Decimal(15, 2)

  @@unique([periodStart, periodEnd, accountId])
  @@index([accountId])
  @@index([periodStart])
  @@map("period_summaries")
}

// ─────────────────────────────────────────────────────────────────────────────
// Upload history — audit trail for workbook imports
// ─────────────────────────────────────────────────────────────────────────────

model UploadHistory {
  id           Int      @id @default(autoincrement())
  filename     String
  checksum     String   @unique  // SHA-256; prevents duplicate imports
  uploadedAt   DateTime @default(now()) @map("uploaded_at")
  rowCount     Int      @default(0) @map("row_count")
  status       String   // "pending" | "processing" | "complete" | "error"
  errorMessage String?  @map("error_message")

  journalEntries JournalEntry[]

  @@map("upload_history")
}
