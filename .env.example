# Lansport Analytics - Environment Variables
# ==========================================
# Copy this file to .env before running the application.
# The START_LANSPORT.bat script will do this automatically on first run.

# ------------------------------------------------------------------
# Database password (used by postgres service and all app services)
# ------------------------------------------------------------------
DB_PASSWORD=lansport_dev

# ------------------------------------------------------------------
# NextAuth secret — CHANGE THIS before exposing to a network.
# Generate one with: openssl rand -base64 32
# ------------------------------------------------------------------
NEXTAUTH_SECRET=change_this_to_a_random_secret_before_production

# ------------------------------------------------------------------
# Application URL (used by NextAuth for redirect URLs)
# ------------------------------------------------------------------
NEXTAUTH_URL=http://localhost

# ------------------------------------------------------------------
# Port for the Nginx reverse proxy (default: 80)
# ------------------------------------------------------------------
APP_PORT=80
